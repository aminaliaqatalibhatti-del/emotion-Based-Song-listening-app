{
  "name": "emotion-based-song-listening-app",
  "version": "1.0.0",
  "description": "An AI-powered emotion-based application that listens to user mood and suggests personalized music and comforting messages. It not only recommends based on emotions but also reads responses aloud and saves user mood history for future tracking and improved recommendations over time.",
