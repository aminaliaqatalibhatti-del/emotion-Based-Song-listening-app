  "scripts": {
    "build": "esbuild app/script.js --bundle --outfile=app/script.bundle.js --format=iife",
    "dev": "esbuild app/script.js --bundle --outfile=app/script.bundle.js --format=iife --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
